{
  "manifest_version": 3,
  "name": "StudyLens Tracker",
  "version": "2.0.0",
  "description": "AI-powered study tracker. Captures video events from YouTube and reading activity from any website you configure as your study platform.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "alarms",
    "idle",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:7842/*",
    "http://127.0.0.1:7842/*",
    "*://*.youtube.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://perplexity.ai/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content_youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://perplexity.ai/*"
      ],
      "js": ["content_ai_chat.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content_website.js"],
      "run_at": "document_idle",
      "exclude_matches": [
        "*://*.youtube.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://perplexity.ai/*",
        "*://localhost/*",
        "*://127.0.0.1/*",
        "*://chrome.google.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "yt_api.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
